# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=trey-golf-pipeline
S3_PREFIX_RAW=raw
S3_PREFIX_KEYPOINTS=keypoints

# MongoDB
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net
MONGO_DB=golf_pipeline

# Temporal
TEMPORAL_TARGET=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=golf-pipeline

# Modal
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# Pose inference routing
# 1 (default) → run pose locally on CPU via extract_pose_local; the worker
#               uploads the .npz itself. Use this on a laptop without Modal
#               configured. Falsy values: 0, false, no, off, empty string.
# 0           → call Modal's GPU function (production path).
LOCAL_DEV=1

# API
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# pipeline
USER_ID=trey
LOG_LEVEL=INFO
PIPELINE_VERSION=0.1.0
