# Repo-root safety net for env files. Real ignores live in
# golf-pipeline/.gitignore — this exists so a stray .env at the repo
# root can't sneak past those subtree-scoped patterns again.
.env
.env.*
!.env.example
!.env.*.example

# Claude Code internals
.claude/

# Ad-hoc debugging scripts (underscore prefix convention)
**/scripts/_*.py

# Log files
*.log
